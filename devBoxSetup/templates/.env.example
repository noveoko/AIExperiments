# Copy to .env in your project root. Never commit .env to git.

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Azure DevOps (prefer az login / GCM over PAT) ---
# AZURE_DEVOPS_EXT_PAT=          # Only if SSO is unavailable
# AZURE_DEVOPS_ORG=https://dev.azure.com/<ORG>
# AZURE_DEVOPS_PROJECT=<PROJECT>

# --- Databricks (prefer: databricks auth login) ---
# DATABRICKS_HOST=https://adb-<workspace-id>.azuredatabricks.net
# DATABRICKS_TOKEN=              # Use CLI profile instead when possible
# DATABRICKS_CLUSTER_ID=

# --- Unity Catalog ---
# UC_CATALOG=dev_catalog
# UC_SCHEMA=etl

# --- Data sources (use Key Vault / secret scopes in production) ---
# SOURCE_CONNECTION_STRING=
# SINK_STORAGE_ACCOUNT=

# --- Local overrides ---
# TRADEUP_DB=tradeup.db
# TRADEUP_SECRET_KEY=dev-secret-change-in-production