# Generated by DevBox Setup Configurator — profile: {{ profile_name }}

trigger:
  branches:
    include:
      - main
      - develop

pr:
  branches:
    include:
      - main
      - develop

pool:
  vmImage: ubuntu-latest

variables:
  packageManager: '{{ ci_package_manager }}'

stages:
  - stage: BuildAndTest
    displayName: Build and Test
    jobs:
      - job: PythonCI
        displayName: Python CI
        strategy:
          matrix:
{% for ver in ci_python_versions %}
            Python{{ ver | replace('.', '') }}:
              pythonVersion: '{{ ver }}'
{% endfor %}
        steps:
          - checkout: self
            fetchDepth: 1

          - task: UsePythonVersion@0
            inputs:
              versionSpec: '$(pythonVersion)'
            displayName: 'Use Python $(pythonVersion)'

          - script: |
              curl -LsSf https://astral.sh/uv/install.sh | sh
              echo "##vso[task.prependpath]$HOME/.local/bin"
            displayName: 'Install uv'
            condition: eq(variables['packageManager'], 'uv')

          - script: uv sync --all-extras --dev
            displayName: 'uv sync'
            condition: eq(variables['packageManager'], 'uv')

          - script: |
              curl -sSL https://install.python-poetry.org | python3 -
              echo "##vso[task.prependpath]$HOME/.local/bin"
              poetry config virtualenvs.in-project true
              poetry install --no-interaction
            displayName: 'Poetry install'
            condition: eq(variables['packageManager'], 'poetry')

          - script: |
              if [ "$(packageManager)" = "uv" ]; then
                uv run ruff check .
                uv run pytest --junitxml=test-results.xml -v
              else
                poetry run ruff check .
                poetry run pytest --junitxml=test-results.xml -v
              fi
            displayName: 'Lint and test'

          - task: PublishTestResults@2
            inputs:
              testResultsFormat: 'JUnit'
              testResultsFiles: 'test-results.xml'
              mergeTestResults: true
            condition: succeededOrFailed()

          - script: |
              if [ "$(packageManager)" = "uv" ]; then
                uv build
              else
                poetry build
              fi
            displayName: 'Build wheel'
            condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/main'))

          - task: PublishPipelineArtifact@1
            inputs:
              targetPath: 'dist'
              artifact: 'python-wheel'
            condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/main'))

{% if include_deploy_stage %}
  - stage: DeployDatabricks
    displayName: Deploy to Databricks
    dependsOn: BuildAndTest
    condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/main'))
    jobs:
      - deployment: DeployWheel
        environment: databricks-dev
        strategy:
          runOnce:
            deploy:
              steps:
                - download: current
                  artifact: python-wheel
                - script: |
                    pip install databricks-cli
                    databricks fs cp dist/*.whl dbfs:/FileStore/wheels/ --overwrite
                  displayName: 'Upload wheel to DBFS'
{% if service_connection_name %}
                  env:
                    DATABRICKS_HOST: {{ databricks_host }}
{% endif %}
{% endif %}