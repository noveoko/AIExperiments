# Generated by DevBox Setup Configurator — upload when creating your DevBox.
# Profile: {{ profile_name }}

$schema: 1.0
name: {{ profile_name }}-user
description: Personal developer setup ({{ environment }})

tasks:
  - name: install-git
    description: Ensure Git for Windows with Credential Manager
    type: winget
    parameters:
      package: Git.Git

  - name: install-azure-cli
    description: Azure CLI for Entra ID SSO authentication
    type: winget
    parameters:
      package: Microsoft.AzureCLI

  - name: install-windows-terminal
    description: Windows Terminal with WSL profile
    type: winget
    parameters:
      package: Microsoft.WindowsTerminal

{% if install_cursor %}
  - name: install-cursor
    description: Cursor IDE
    type: winget
    parameters:
      package: Cursor.Cursor
{% endif %}
{% if install_vscode %}
  - name: install-vscode
    description: Visual Studio Code
    type: winget
    parameters:
      package: Microsoft.VisualStudioCode
{% endif %}
{% if ado_clone_url %}

  - name: clone-devbox-setup
    description: Clone bootstrap repository for WSL setup scripts
    type: git-clone
    parameters:
      repositoryUrl: {{ ado_clone_url }}
      path: {{ devbox_setup_path }}
{% endif %}

  - name: run-wsl-bootstrap
    description: Run WSL bootstrap after Ubuntu is available
    type: powershell
    parameters:
      script: |
        $setupRoot = "{{ devbox_setup_path }}"
        if (Test-Path $setupRoot) {
          $wslPath = wsl wslpath -a $setupRoot
          wsl -d {{ wsl_distro }} bash "$wslPath/wsl/bootstrap.sh"
        } else {
          Write-Host "devBoxSetup not found at $setupRoot — clone repo first"
        }