# Generated by DevBox Setup Configurator — profile: {{ profile_name }}
# LOCAL ONLY — never commit this file to git.

APP_ENV=development
LOG_LEVEL=INFO

# Git
GIT_USER_NAME={{ git_user_name }}
GIT_USER_EMAIL={{ git_user_email }}

# Azure DevOps
AZURE_DEVOPS_ORG={{ ado_org_url }}
AZURE_DEVOPS_PROJECT={{ ado_project }}
ADO_AUTH_METHOD={{ ado_auth_method }}
{% if ado_pat and ado_auth_method == 'pat' %}
AZURE_DEVOPS_EXT_PAT={{ ado_pat }}
{% endif %}

# Databricks
DATABRICKS_HOST={{ databricks_host }}
DATABRICKS_AUTH={{ databricks_auth }}
{% if databricks_token and databricks_auth == 'token' %}
DATABRICKS_TOKEN={{ databricks_token }}
{% endif %}
DATABRICKS_CONNECT_VERSION={{ databricks_connect_version }}

# Unity Catalog
UC_CATALOG_DEV={{ uc_catalog_dev }}
UC_CATALOG_PROD={{ uc_catalog_prod }}
UC_SCHEMA={{ uc_schema }}

# Python
PYTHON_DEFAULT={{ python_default }}
PACKAGE_MANAGER_DEFAULT={{ package_manager_default }}

# DevBox
DEVBOX_SETUP_PATH={{ devbox_setup_path }}
WSL_DISTRO={{ wsl_distro }}