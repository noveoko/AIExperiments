# Generated by DevBox Setup Configurator — submit to IT for dev box pool attachment.
# Profile: {{ profile_name }}

$schema: 1.0
name: {{ profile_name }}-team
description: Standard developer DevBox configuration ({{ environment }})

tasks:
  - name: enable-wsl
    description: Enable WSL2 platform feature
    type: powershell
    context: system
    parameters:
      script: |
        wsl --install --no-distribution
        wsl --set-default-version 2

  - name: install-ubuntu
    description: Install {{ wsl_distro }} WSL distro
    type: winget
    context: system
    parameters:
      package: {% if wsl_distro == "Ubuntu-24.04" %}Canonical.Ubuntu.2404{% elif wsl_distro == "Ubuntu-22.04" %}Canonical.Ubuntu.2204{% else %}Canonical.Ubuntu.2404{% endif %}

  - name: install-openssh-client
    description: SSH client for Azure Repos and Databricks
    type: winget
    context: system
    parameters:
      package: Microsoft.OpenSSH.Beta

  - name: install-git
    description: Git for Windows with Credential Manager
    type: winget
    context: user
    parameters:
      package: Git.Git

  - name: install-azure-cli
    description: Azure CLI for corporate Entra ID auth
    type: winget
    context: user
    parameters:
      package: Microsoft.AzureCLI

  - name: install-windows-terminal
    description: Windows Terminal
    type: winget
    context: user
    parameters:
      package: Microsoft.WindowsTerminal

{% if install_cursor %}
  - name: install-cursor
    description: Cursor IDE
    type: winget
    context: user
    parameters:
      package: Cursor.Cursor
{% endif %}
{% if install_vscode %}
  - name: install-vscode
    description: Visual Studio Code
    type: winget
    context: user
    parameters:
      package: Microsoft.VisualStudioCode
{% endif %}

  - name: configure-wslconfig
    description: Apply WSL resource limits
    type: powershell
    context: user
    parameters:
      script: |
        $config = @"
        [wsl2]
        memory={{ wsl_memory_gb }}GB
        processors={{ wsl_processors }}
        swap={{ wsl_swap_gb }}GB
        localhostForwarding=true
        "@
        $path = "$env:USERPROFILE\.wslconfig"
        Set-Content -Path $path -Value $config -Force