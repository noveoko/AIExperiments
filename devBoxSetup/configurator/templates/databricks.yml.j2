# Generated by DevBox Setup Configurator — profile: {{ profile_name }}

bundle:
  name: {{ bundle_name }}

variables:
  catalog:
    description: Unity Catalog name
    default: {{ uc_catalog_dev }}
  schema:
    description: Target schema
    default: {{ uc_schema }}

artifacts:
  default:
    type: whl
    build: {{ ci_package_manager }} build
    path: .

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: {{ databricks_host }}
    variables:
      catalog: {{ uc_catalog_dev }}
      schema: {{ uc_schema }}

  prod:
    mode: production
    workspace:
      host: {{ databricks_host }}
    variables:
      catalog: {{ uc_catalog_prod }}
      schema: {{ uc_schema }}

resources:
  jobs:
    etl_job:
      name: "[${bundle.target}] ETL Pipeline"
      tasks:
        - task_key: run_etl
          job_cluster_key: etl_cluster
          python_wheel_task:
            package_name: {{ package_name }}
            entry_point: main
            named_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
          libraries:
            - whl: ./dist/*.whl

      job_clusters:
        - job_cluster_key: etl_cluster
          new_cluster:
            spark_version: "{{ databricks_runtime }}"
            node_type_id: "{{ node_type_id }}"
            num_workers: {{ num_workers }}
            spark_conf:
              spark.databricks.delta.preview.enabled: "true"
            custom_tags:
              project: {{ bundle_name }}
              environment: ${bundle.target}